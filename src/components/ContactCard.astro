---
export interface Props {
  accent: string;
  name: string;
  handle: string;
  description: string;
  actionText: string;
  href?: string;
  copyValue?: string;
  handleColor?: string;
  mobileHref?: string;
  androidHref?: string;
  iosAppHref?: string;
}

const { accent, name, handle, description, actionText, href, copyValue, handleColor, mobileHref, androidHref, iosAppHref } = Astro.props;
---

<div class="contact-card flex-1 max-w-[400px] min-w-[280px]" style={`--accent-glow: ${accent};`}>
  <div class="card-glow"></div>
  <div class="contact-icon-wrapper">
    <slot name="icon" />
  </div>
  <h3>{name}</h3>
  <p class="handle" style={handleColor ? `color: ${handleColor}; filter: none;` : undefined}>{handle}</p>
  <p class="description">{description}</p>
  {copyValue ? (
    <button type="button" class="action-text" data-copy={copyValue} data-default-text={actionText}>{actionText}</button>
  ) : (
    <a
      href={href}
      target="_blank"
      rel="noopener noreferrer"
      class="action-text"
      data-mobile-href={mobileHref}
      data-android-href={androidHref}
      data-ios-app-href={iosAppHref}
    >{actionText}</a>
  )}
</div>
