---
import { Icon } from 'astro-icon/components';

export interface Props {
  badge: string;
  icon: string;
  accent: string;
  title: string;
  description: string;
  current?: boolean;
  destination?: boolean;
}

const { badge, icon, accent, title, description, current = false, destination = false } = Astro.props;
---

<div class:list={['roadmap-card', { 'destination-card': destination }]} style={`--accent-glow: ${accent};`}>
  <div class="card-glow"></div>
  <div class="card-icon"><Icon name={icon} /></div>
  <div class="card-body">
    <div class="card-title-row">
      <h3>{title}</h3>
      <div class:list={['card-badge', { current }]}>{badge}</div>
    </div>
    <p set:html={description} />
  </div>
</div>
