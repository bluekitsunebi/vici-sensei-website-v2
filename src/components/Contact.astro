---
import { Icon } from 'astro-icon/components';
import ContactCard from './ContactCard.astro';
---

<section id="connect" class="section-padding">
  <div class="site-container">
    <div class="header-center">
      <span class="badge">GET IN TOUCH</span>
      <h2 class="main-title">Connect With Me Directly</h2>
      <p class="subtitle">Ready to start your journey? Drop me a message on your preferred platform or contact me through email or phone.</p>
    </div>

    <div class="flex justify-center flex-wrap gap-8">
      <ContactCard
        accent="#5865F2"
        name="Discord"
        handle="vici5287"
        description="Got questions or want to enroll? Drop me a message or a friend request and I will answer as soon as possible."
        actionText="Connect on Discord →"
        appHref="discord://-/users/114122034321031175"
        webHref="https://discord.com/users/114122034321031175"
      >
        <Fragment slot="icon">
          <Icon name="simple-icons:discord" class="contact-svg" />
        </Fragment>
      </ContactCard>

      <ContactCard
        accent="#25D366"
        name="WhatsApp"
        handle="+40 745 984 726"
        description="Have personal questions about the mentorship structure or enrollment availability? Let's chat directly."
        actionText="Message Directly →"
        href="https://wa.me/40745984726"
      >
        <Fragment slot="icon">
          <Icon name="simple-icons:whatsapp" class="contact-svg" />
        </Fragment>
      </ContactCard>
    </div>
  </div>
</section>

<script>
  // Try to open the native app via its custom URI scheme; if the app doesn't
  // take over the window within the timeout, fall back to the web link.
  document.querySelectorAll<HTMLAnchorElement>('[data-app-href]').forEach((link) => {
    link.addEventListener('click', (event) => {
      const appUrl = link.dataset.appHref;
      if (!appUrl) return;

      event.preventDefault();

      let appOpened = false;
      const onBlur = () => {
        appOpened = true;
      };
      window.addEventListener('blur', onBlur, { once: true });

      window.location.href = appUrl;

      setTimeout(() => {
        window.removeEventListener('blur', onBlur);
        if (!appOpened) {
          window.open(link.href, '_blank', 'noopener,noreferrer');
        }
      }, 900);
    });
  });

  // Support any future contact method that just needs a "copy to clipboard" action.
  document.querySelectorAll<HTMLButtonElement>('[data-copy]').forEach((button) => {
    button.addEventListener('click', async () => {
      const value = button.dataset.copy ?? '';
      const defaultText = button.dataset.defaultText ?? button.textContent ?? '';

      try {
        await navigator.clipboard.writeText(value);
        button.textContent = 'Copied — paste it in Discord →';
      } catch (error) {
        button.textContent = `Copy failed — username: ${value}`;
      }

      setTimeout(() => {
        button.textContent = defaultText;
      }, 2500);
    });
  });
</script>
