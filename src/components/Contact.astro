---
import ContactCard from './ContactCard.astro';
---

<section id="connect" class="section-padding">
  <div class="container">
    <div class="header-center">
      <span class="badge">GET IN TOUCH</span>
      <h2 class="main-title">Connect With Me Directly</h2>
      <p class="subtitle">Ready to start your journey? Drop me a message on your preferred platform or contact me through email or phone.</p>
    </div>

    <div class="contact-grid" style="display: flex; justify-content: center; flex-wrap: wrap; gap: 2rem;">
      <ContactCard
        accent="#5865F2"
        name="Discord"
        handle="vici5287"
        description="Got questions or want to enroll? Drop me a message or a friend request and I will answer as soon as possible."
        actionText="Connect on Discord →"
        appHref="discord://-/users/114122034321031175"
        webHref="https://discord.com/users/114122034321031175"
      >
        <Fragment slot="icon">
          <svg class="contact-svg" viewBox="0 0 127.14 96.36" fill="currentColor">
            <path d="M107.7,8.07A105.15,105.15,0,0,0,77.26,0a77.19,77.19,0,0,0-3.3,6.83A96.67,96.67,0,0,0,53.22,6.83,77.19,77.19,0,0,0,49.88,0,105.15,105.15,0,0,0,19.44,8.07C3.66,31.58-1.86,54.65,1,77.53A105.73,105.73,0,0,0,32,96.36a74.37,74.37,0,0,0,6.72-10.93,68.6,68.6,0,0,1-10.64-5.12c.91-.66,1.8-1.34,2.65-2a75.58,75.58,0,0,0,72.86,0c.85.69,1.74,1.37,2.65,2a68.42,68.42,0,0,1-10.64,5.12,74.74,74.74,0,0,0,6.72,10.93,105.73,105.73,0,0,0,31-18.83C129.1,49.7,122.64,26.9,107.7,8.07ZM42.45,65.69C36.18,65.69,31,60,31,53S36.18,40.36,42.45,40.36,53.83,46,53.83,53,48.72,65.69,42.45,65.69Zm42.24,0C78.41,65.69,73.24,60,73.24,53S78.41,40.36,84.69,40.36,96.07,46,96.07,53,91,65.69,84.69,65.69Z"></path>
          </svg>
        </Fragment>
      </ContactCard>

      <ContactCard
        accent="#25D366"
        name="WhatsApp"
        handle="+40 745 984 726"
        description="Have personal questions about the mentorship structure or enrollment availability? Let's chat directly."
        actionText="Message Directly →"
        href="https://wa.me/40745984726"
      >
        <Fragment slot="icon">
          <svg class="contact-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
          </svg>
        </Fragment>
      </ContactCard>
    </div>
  </div>
</section>

<script>
  // Try to open the native app via its custom URI scheme; if the app doesn't
  // take over the window within the timeout, fall back to the web link.
  document.querySelectorAll<HTMLAnchorElement>('[data-app-href]').forEach((link) => {
    link.addEventListener('click', (event) => {
      const appUrl = link.dataset.appHref;
      if (!appUrl) return;

      event.preventDefault();

      let appOpened = false;
      const onBlur = () => {
        appOpened = true;
      };
      window.addEventListener('blur', onBlur, { once: true });

      window.location.href = appUrl;

      setTimeout(() => {
        window.removeEventListener('blur', onBlur);
        if (!appOpened) {
          window.open(link.href, '_blank', 'noopener,noreferrer');
        }
      }, 900);
    });
  });

  // Support any future contact method that just needs a "copy to clipboard" action.
  document.querySelectorAll<HTMLButtonElement>('[data-copy]').forEach((button) => {
    button.addEventListener('click', async () => {
      const value = button.dataset.copy ?? '';
      const defaultText = button.dataset.defaultText ?? button.textContent ?? '';

      try {
        await navigator.clipboard.writeText(value);
        button.textContent = 'Copied — paste it in Discord →';
      } catch (error) {
        button.textContent = `Copy failed — username: ${value}`;
      }

      setTimeout(() => {
        button.textContent = defaultText;
      }, 2500);
    });
  });
</script>
