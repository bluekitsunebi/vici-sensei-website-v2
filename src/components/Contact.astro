---
import { Icon } from 'astro-icon/components';
import ContactCard from './ContactCard.astro';
---

<section id="connect" class="section-padding">
  <div class="site-container">
    <div class="header-center">
      <span class="badge">GET IN TOUCH</span>
      <h2 class="main-title">Connect With Me Directly</h2>
      <p class="subtitle">Ready to start your journey? Drop me a message on your preferred platform or contact me through email or phone.</p>
    </div>

    <div class="flex justify-center flex-wrap gap-8">
      <ContactCard
        accent="#5865F2"
        name="Discord"
        handle="vici5287"
        description="Got questions or want to enroll? Drop me a message or a friend request and I will answer as soon as possible."
        actionText="Connect on Discord →"
        href="https://discord.com/users/114122034321031175"
      >
        <Fragment slot="icon">
          <Icon name="simple-icons:discord" class="contact-svg" />
        </Fragment>
      </ContactCard>

      <ContactCard
        accent="#25D366"
        name="WhatsApp"
        handle="+40 745 984 726"
        description="Have personal questions about the mentorship structure or enrollment availability? Let's chat directly."
        actionText="Message Directly →"
        href="https://web.whatsapp.com/send?phone=40745984726"
        mobileHref="https://wa.me/40745984726"
      >
        <Fragment slot="icon">
          <Icon name="simple-icons:whatsapp" class="contact-svg" />
        </Fragment>
      </ContactCard>

      <ContactCard
        accent="#EA4335"
        name="Gmail"
        handle="vici.sensei@gmail.com"
        description="Prefer email? Send me a detailed message and I'll follow up with everything you need to know."
        actionText="Send an Email →"
        href="https://mail.google.com/mail/?view=cm&fs=1&to=vici.sensei@gmail.com&su=Japanese+Mentorship+Program+Inquiry"
        androidHref="intent://vici.sensei@gmail.com?subject=Japanese%20Mentorship%20Program%20Inquiry#Intent;scheme=mailto;package=com.google.android.gm;S.browser_fallback_url=https%3A%2F%2Fmail.google.com%2Fmail%2F%3Fview%3Dcm%26fs%3D1%26to%3Dvici.sensei%2540gmail.com%26su%3DJapanese%2BMentorship%2BProgram%2BInquiry;end"
        iosAppHref="googlegmail:///co?to=vici.sensei@gmail.com&subject=Japanese%20Mentorship%20Program%20Inquiry"
      >
        <Fragment slot="icon">
          <Icon name="simple-icons:gmail" class="contact-svg" />
        </Fragment>
      </ContactCard>
    </div>
  </div>
</section>

<script>
  // Detect mobile OS by user agent, not viewport width — a resized desktop
  // window should still link to the desktop web apps.
  const ua = navigator.userAgent;
  const isIOS = /iPhone|iPad|iPod/i.test(ua);
  const isAndroid = /Android/i.test(ua);

  // Links with a same-scheme mobile alternative (e.g. wa.me) can just swap
  // their href outright — no app-detection trickery needed.
  if (isIOS || isAndroid) {
    document.querySelectorAll<HTMLAnchorElement>('[data-mobile-href]').forEach((link) => {
      const mobileHref = link.dataset.mobileHref;
      if (mobileHref) link.href = mobileHref;
    });
  }

  // Android intent:// URLs carry their own native fallback, so this is
  // likewise a plain href swap.
  if (isAndroid) {
    document.querySelectorAll<HTMLAnchorElement>('[data-android-href]').forEach((link) => {
      const androidHref = link.dataset.androidHref;
      if (androidHref) link.href = androidHref;
    });
  }

  // iOS custom URL schemes have no native fallback (Apple blocks the usual
  // JS redirect trick from running reliably), so fall back manually: try the
  // app, and if the tab never loses focus, open the original web link.
  if (isIOS) {
    document.querySelectorAll<HTMLAnchorElement>('[data-ios-app-href]').forEach((link) => {
      const appHref = link.dataset.iosAppHref;
      if (!appHref) return;

      link.addEventListener('click', (event) => {
        event.preventDefault();

        let appOpened = false;
        const onBlur = () => {
          appOpened = true;
        };
        window.addEventListener('blur', onBlur, { once: true });

        window.location.href = appHref;

        setTimeout(() => {
          window.removeEventListener('blur', onBlur);
          if (!appOpened) {
            window.open(link.href, '_blank', 'noopener,noreferrer');
          }
        }, 900);
      });
    });
  }

  // Support any future contact method that just needs a "copy to clipboard" action.
  document.querySelectorAll<HTMLButtonElement>('[data-copy]').forEach((button) => {
    button.addEventListener('click', async () => {
      const value = button.dataset.copy ?? '';
      const defaultText = button.dataset.defaultText ?? button.textContent ?? '';

      try {
        await navigator.clipboard.writeText(value);
        button.textContent = 'Copied — paste it in Discord →';
      } catch (error) {
        button.textContent = `Copy failed — username: ${value}`;
      }

      setTimeout(() => {
        button.textContent = defaultText;
      }, 2500);
    });
  });
</script>
