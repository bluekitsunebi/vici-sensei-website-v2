<!-- PRICING -->
<section id="pricing" class="section-padding">
  <div class="header-center mb-[50px]">
    <span class="badge text-[0.75rem] uppercase">START YOUR JOURNEY</span>

    <!-- Clear Section Marker -->
    <h2 class="main-title text-white text-[2.5rem] mt-[15px] mb-0 tracking-[-0.5px]">Transparent Pricing</h2>

    <!-- Supporting Value Statement -->
    <p class="subtitle mt-[15px] mb-0"> Get everything you need to master Japanese, built into one seamless, high-touch ecosystem.</p>
  </div>

  <!-- Cardul principal Premium (Section-Card Layout) -->
  <div class="max-w-[590px] mx-auto bg-[#0f1524] rounded-[20px] border border-[rgba(255,74,90,0.15)] shadow-[0_20px_40px_rgba(0,0,0,0.45)] overflow-hidden">

    <!-- Partea de sus: Detalii și Preț -->
    <div class="px-[45px] max-md:px-2 pt-[45px] pb-[15px]">
      <div class="flex flex-row max-md:flex-col-reverse justify-between items-center gap-4 max-md:mb-1">
        <h3 class="m-0 text-[1.8rem] text-white max-md:text-center font-bold">Full-Access Mentorship</h3>
        <span class="badge text-[0.75rem] px-3 py-[5px] bg-accent-red text-white text-center font-bold rounded-[20px] tracking-[0.5px] h-fit w-fit whitespace-nowrap">ALL-INCLUDED</span>
      </div>
      <p class="text-text-muted text-[1.05rem] leading-[1.6] mb-[30px] max-md:text-center">Bring your motivation with you. Everything else is taken care of.</p>

      <!-- Prețuri Dinamice -->
      <div class="mt-[15px] mb-2 max-md:text-center leading-tight">
        <span id="base-price" class="text-[3rem] font-extrabold text-white tracking-[-1px] whitespace-nowrap">$119</span> <span class="text-text-muted text-[1.2rem] whitespace-nowrap">/ 4 weeks</span>
      </div>
    </div>

    <!-- Partea de mijloc: Secțiunea de caracteristici cu fundal contrastant subtil -->
    <div class="bg-[rgba(0,0,0,0.15)] px-[45px] max-md:px-4 py-10 border-t border-b border-[rgba(255,255,255,0.03)]">
      <h4 class="text-[rgba(255,255,255,0.4)] text-[0.85rem] font-bold mb-6 tracking-[1.5px] uppercase max-md:text-center">What's included in your program:</h4>

      <ul class="list-none m-0 p-0 flex flex-col gap-[14px]">
        <li class="flex items-center gap-2.5 mb-[18px] text-[#cbd5e1] text-[1.05rem] leading-[1.5] before:content-['✓'] before:font-black before:text-accent-red">
          <span><strong class="highlight">4 Premium 1-Hour Live Sessions</strong> (individual pace in a group of 4 – based on my <a href="#methodology"><u>Three-Pillar System</u></a>)</span>
        </li>
        <li class="flex items-center gap-2.5 mb-[18px] text-[#cbd5e1] text-[1.05rem] leading-[1.5] before:content-['✓'] before:font-black before:text-accent-red">
          <span><strong class="highlight">Personalized Study Roadmap</strong> (tailored to your specific goals)</span>
        </li>
        <li class="flex items-center gap-2.5 mb-[18px] text-[#cbd5e1] text-[1.05rem] leading-[1.5] before:content-['✓'] before:font-black before:text-accent-red">
          <span>Unlimited Access to the <strong class="highlight">Custom Kanji & Vocab App</strong></span>
        </li>
      </ul>
    </div>

    <!-- Partea de jos: Butonul principal pus ca o concluzie curată -->
    <div class="px-[45px] pt-[35px] pb-[45px] text-center">
      <a href="#connect" class="btn-primary block text-center p-[18px] text-[1.1rem] max-md:w-fit max-md:mx-auto">Join the Mentorship</a>
    </div>
  </div>
</section>
