<!-- PRICING -->
<section id="pricing">
  <div class="header-center" style="margin-bottom: 50px; text-align: center;">
    <span class="badge" style="font-size: 0.75rem; background: rgba(255, 74, 90, 0.1); color: #ff4a5a; padding: 6px 16px; border-radius: 100px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase;">START YOUR JOURNEY</span>

    <!-- Clear Section Marker -->
    <h2 class="main-title" style="color: #fff; font-size: 2.5rem; font-weight: 800; margin-top: 15px; margin-bottom: 0; letter-spacing: -0.5px;">Transparent Pricing</h2>

    <!-- Supporting Value Statement -->
    <p class="subtitle" style="color: var(--text-muted); max-width: 600px; margin: 15px auto 0;"> Get everything you need to master Japanese, built into one seamless, high-touch ecosystem.</p>
  </div>

  <!-- Cardul principal Premium (Section-Card Layout) -->
  <div class="pricing-card-container" style="max-width: 550px; margin: 0 auto; background: #0f1524; border-radius: 20px; border: 1px solid rgba(255, 74, 90, 0.15); box-shadow: 0 20px 40px rgba(0,0,0,0.45); overflow: hidden;">

    <!-- Partea de sus: Detalii și Preț -->
    <div style="padding: 45px 45px 35px 45px;">
      <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12px;">
        <h3 style="margin: 0; font-size: 1.8rem; color: #fff; font-weight: 700;">Full-Access Mentorship</h3>
        <span class="badge" style="font-size: 0.75rem; padding: 5px 12px; background: var(--accent-red); color: #fff; font-weight: bold; border-radius: 20px; letter-spacing: 0.5px;">ALL-INCLUDED</span>
      </div>
      <p style="color: var(--text-muted); font-size: 1.05rem; line-height: 1.6; margin: 0 0 30px 0;">Bring your motivation with you. Everything else is taken care of.</p>

      <!-- Prețuri Dinamice -->
      <div class="price-amount" style="margin-bottom: 8px;">
        <span class="price-num" id="base-price" style="font-size: 3rem; font-weight: 800; color: #fff; letter-spacing: -1px;">$129</span><span style="color: var(--text-muted); font-size: 1.1rem;"> / 4 weeks</span>
      </div>
    </div>

    <!-- Partea de mijloc: Secțiunea de caracteristici cu fundal contrastant subtil -->
    <div style="background: rgba(0, 0, 0, 0.15); padding: 40px 45px; border-top: 1px solid rgba(255,255,255,0.03); border-bottom: 1px solid rgba(255,255,255,0.03);">
      <h4 style="color: rgba(255,255,255,0.4); font-size: 0.85rem; font-weight: 700; margin: 0 0 24px 0; letter-spacing: 1.5px; text-transform: uppercase;">What's included in your program:</h4>

      <ul class="price-features" style="margin: 0; padding: 0; list-style: none;">
        <li style="margin-bottom: 18px; color: #cbd5e1; font-size: 1.05rem; line-height: 1.5;">
          <span><strong class="highlight" style="color: #fff; font-weight: 600;">4 Premium 1-Hour Live Sessions</strong> (individual pace in a group of 4 – based on my <a href="#methodology"><u>Three-Pillar System</u></a>)</span>
        </li>
        <li style="margin-bottom: 18px; color: #cbd5e1; font-size: 1.05rem; line-height: 1.5;">
          <span><strong class="highlight">Personalized Study Roadmap</strong> (tailored to your specific goals)</span>
        </li>
        <li style="margin-bottom: 18px; color: #cbd5e1; font-size: 1.05rem; line-height: 1.5;">
          <span>Unlimited Access to the <strong class="highlight">Custom Kanji & Vocab App</strong></span>
        </li>
      </ul>
    </div>

    <!-- Partea de jos: Butonul principal pus ca o concluzie curată -->
    <div style="padding: 35px 45px 45px 45px; text-align: center;">
      <a href="#connect" class="btn-primary" style="text-align: center; display: block; padding: 18px; text-decoration: none; font-weight: 700; font-size: 1.1rem; border-radius: 12px; transition: transform 0.2s, box-shadow: 0 8px 24px rgba(255, 74, 90, 0.35);">Join the Mentorship</a>
    </div>
  </div>
</section>

<!-- SCRIPT PENTRU DETECTARE LOCAȚIE ȘI SCHIMBARE PREȚURI -->
<script>
  document.addEventListener('DOMContentLoaded', function () {
    const basePriceEl = document.getElementById('base-price');
    const promoPriceEl = document.getElementById('promo-price');

    const timezone = Intl.DateTimeFormat().resolvedOptions().timeZone;

    if (timezone.includes('Bucharest')) {
      updatePrices('440 RON', '240 RON');
    } else {
      fetch('https://ipapi.co/json/')
        .then((response) => response.json())
        .then((data) => {
          if (data.country === 'RO') {
            updatePrices('440 RON', '240 RON');
          } else if (
            data.in_eu ||
            ['AT', 'BE', 'CY', 'EE', 'FI', 'FR', 'DE', 'GR', 'IE', 'IT', 'LV', 'LT', 'LU', 'MT', 'NL', 'PT', 'SK', 'SI', 'ES'].includes(data.country)
          ) {
            updatePrices('129 €', '79 €');
          } else {
            updatePrices('$129', '$79');
          }
        })
        .catch((error) => {
          console.log('Location detection fallback applied.');
        });
    }

    function updatePrices(base: string, promo: string) {
      basePriceEl!.textContent = base;
      promoPriceEl!.textContent = promo;
    }
  });

  document.addEventListener('DOMContentLoaded', () => {
    localizePricing();
  });

  async function localizePricing() {
    const priceNum = document.querySelector('.price-num');
    const priceSubtext = document.querySelector('.pricing-subtext');
    if (!priceNum || !priceSubtext) return;

    try {
      const response = await fetch('https://ipapi.co/json/');
      const data = await response.json();
      const currency = data.currency;

      if (currency === 'GBP') {
        priceNum.textContent = '£99';
        priceSubtext.innerHTML = 'Bring 2 friends and form your own group!';
      } else if (currency === 'EUR') {
        priceNum.textContent = '99€';
        priceSubtext.innerHTML = 'Bring 2 friends and form your own group!';
      } else if (currency === 'RON') {
        priceNum.textContent = '399 RON';
        priceSubtext.innerHTML = 'Aduceți 2 prieteni și formați-vă propria grupă!';
      } else {
        priceNum.textContent = '$119';
        priceSubtext.innerHTML = 'Bring 2 friends and form your own group!';
      }
    } catch (error) {
      priceNum.textContent = '$119';
      priceSubtext.innerHTML = 'Bring 2 friends and form your own group!';
    }
  }
</script>
