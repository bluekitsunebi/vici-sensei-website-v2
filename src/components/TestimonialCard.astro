---
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

export interface Props {
  name: string;
  flag: string;
  role: string;
  roleClass?: string;
  quote: string;
  translated?: boolean;
  quoteOriginal?: string;
  icon: string;
  photo?: ImageMetadata;
  index: number;
  isLong: boolean;
}

const {
  name,
  flag,
  role,
  roleClass = 'text-accent-blue',
  quote,
  translated = false,
  quoteOriginal,
  icon,
  photo,
  index,
  isLong,
} = Astro.props;
---

<div class:list={['testimonial-card', { 'has-more': isLong }]} data-index={index}>
  <div class="card-glow pointer-events-none absolute inset-0 rounded-2xl opacity-0"></div>
  <div class="flex items-center gap-[14px]">
    {
      photo ? (
        <Image src={photo} alt={name} width={96} height={96} class="testimonial-avatar-photo" />
      ) : (
        <div class="testimonial-avatar-fallback">
          <Icon name={icon} class="h-6 w-6" aria-hidden="true" />
        </div>
      )
    }
    <div>
      <h4 class="flex items-center gap-1.5 text-[1.05rem] font-bold text-white">
        {name} <span class="text-[0.95rem]">{flag}</span>
      </h4>
      <p class={`text-[0.85rem] font-semibold ${roleClass}`}>{role}</p>
    </div>
  </div>
  <div class="flex items-center gap-1" aria-label="5 out of 5 stars">
    {
      Array.from({ length: 5 }).map(() => (
        <Icon name="mdi:star" class="h-[18px] w-[18px] text-accent-gold" aria-hidden="true" />
      ))
    }
    <span class="ml-1.5 text-[0.85rem] font-bold text-text-muted">5.0/5.0</span>
  </div>
  <div class="quote-block">
    <p class:list={['testimonial-quote', { 'line-clamp-4': isLong }]}>
      <span class="quote-text" data-translated={quote} data-original={quoteOriginal}>
        {quote}
      </span>
    </p>
    {
      translated && (
        <span class="mt-1 flex flex-wrap items-center justify-between gap-x-2 gap-y-0.5 text-[0.75rem] text-white/25">
          <span>(Translated from Japanese)</span>
          <button
            type="button"
            class="see-original-btn shrink-0 cursor-pointer bg-transparent p-0 font-bold text-white/25 hover:text-white/30 hover:underline"
            data-state="translated"
          >
            see original
          </button>
        </span>
      )
    }
  </div>
  {
    isLong && (
      <button
        class="see-more-btn -mt-2 cursor-pointer self-start bg-transparent p-0 text-[0.85rem] font-semibold text-accent-blue hover:underline"
        data-index={index}
        type="button"
      >
        See more
      </button>
    )
  }
  <div class="testimonial-mobile-actions"></div>
</div>
